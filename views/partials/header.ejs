<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Moeller Crusaders Baseball' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-moeller">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <img src="/img/moeller-logo.png" alt="Moeller" height="36" class="me-2">
        <span>Moeller Crusaders Baseball</span>
      </a>
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="d-flex align-items-center">
        <% if (user.role === 'coach') { %>
        <a href="/coach" class="btn btn-sm btn-outline-light me-2">Dashboard</a>
        <a href="/coach/print" class="btn btn-sm btn-outline-light me-2">Print</a>
        <% } %>
        <a href="/entry" class="btn btn-sm btn-outline-light me-2">Entry</a>
        <span class="text-light me-3 d-none d-md-inline"><small><%= user.username %></small></span>
        <a href="/logout" class="btn btn-sm btn-outline-light">Logout</a>
      </div>
      <% } %>
    </div>
  </nav>
  <main class="container-fluid mt-3">
